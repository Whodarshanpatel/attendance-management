{
  "name": "attendance-management-system",
  "version": "1.0.0",
  "description": "MEAN Stack Attendance Management System",
  "scripts": {
    "start:db": "mongod --config $(brew --prefix)/etc/mongod.conf --fork || true",
    "start:backend": "cd backend && npm start",
    "dev:backend": "cd backend && npm run dev",
    "start:frontend": "cd frontend && npm run start",
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "dev": "npm run start:db && concurrently \"cd backend && npm run dev\" \"cd frontend && npm start\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
